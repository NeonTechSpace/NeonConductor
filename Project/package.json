{
    "name": "neon-conductor",
    "private": true,
    "version": "0.0.1",
    "description": "AI agent manager with Kilo integration and BYOK support.",
    "homepage": "https://github.com/NeonTechSpace/NeonConductor",
    "packageManager": "pnpm@11.1.2",
    "author": {
        "name": "Neonsy",
        "email": "118444485+Neonsy@users.noreply.github.com"
    },
    "type": "module",
    "engines": {
        "node": "24.14.1",
        "pnpm": "11.1.2"
    },
    "main": "dist-electron/index.js",
    "scripts": {
        "dev": "vite",
        "generated:check": "tsx scripts/generated-artifacts.ts --check",
        "generated:update": "tsx scripts/generated-artifacts.ts",
        "health:baseline": "tsx scripts/health.ts --profile=baseline",
        "health:quick": "tsx scripts/health.ts --profile=quick",
        "health:ci": "tsx scripts/health.ts --profile=ci",
        "health:full": "tsx scripts/health.ts --profile=full",
        "health:alpha-exit": "tsx scripts/health.ts --profile=alpha-exit",
        "report:health-baseline": "tsx scripts/health-baseline.ts",
        "report:health-baseline:json": "tsx scripts/health-baseline.ts --json",
        "report:health-baseline:worklist": "tsx scripts/health-baseline.ts --worklist",
        "report:agents": "tsx scripts/audit-agents-conformance.ts --report",
        "report:agents:json": "tsx scripts/audit-agents-conformance.ts --json --report",
        "report:agents:worklist": "tsx scripts/audit-agents-conformance.ts --worklist --report",
        "report:agents:worklist:new": "tsx scripts/audit-agents-conformance.ts --worklist --report --new-only",
        "report:agents:worklist:stale": "tsx scripts/audit-agents-conformance.ts --worklist --report --stale-only",
        "report:alpha": "tsx scripts/alpha-acceptance.ts",
        "report:alpha:json": "tsx scripts/alpha-acceptance.ts --json",
        "report:alpha:check": "tsx scripts/alpha-acceptance.ts --check",
        "report:alpha-evals": "tsx scripts/alpha-evals.ts",
        "report:alpha-evals:json": "tsx scripts/alpha-evals.ts --json",
        "report:alpha-evals:check": "tsx scripts/alpha-evals.ts --check",
        "marketplace:catalog:check": "tsx scripts/marketplace-catalog.ts --check",
        "desktop:doctor": "tsx scripts/doctor-desktop.ts",
        "desktop:doctor:dev": "tsx scripts/doctor-desktop.ts --scope=development",
        "desktop:launch": "tsx scripts/launch-electron.ts",
        "review:agents": "tsx scripts/audit/review-command.ts",
        "vendor:node": "tsx scripts/vendor-node.ts",
        "vendor:node:win": "tsx scripts/vendor-node.ts --target=win32-x64",
        "vendor:node:mac": "tsx scripts/vendor-node.ts --target=darwin-arm64 --target=darwin-x64",
        "vendor:node:mac:arm64": "tsx scripts/vendor-node.ts --target=darwin-arm64",
        "vendor:node:mac:x64": "tsx scripts/vendor-node.ts --target=darwin-x64",
        "vendor:node:linux": "tsx scripts/vendor-node.ts --target=linux-x64",
        "vendor:rg": "tsx scripts/vendor-rg.ts",
        "vendor:rg:win": "tsx scripts/vendor-rg.ts --target=win32-x64",
        "vendor:rg:mac": "tsx scripts/vendor-rg.ts --target=darwin-arm64 --target=darwin-x64",
        "vendor:rg:mac:arm64": "tsx scripts/vendor-rg.ts --target=darwin-arm64",
        "vendor:rg:mac:x64": "tsx scripts/vendor-rg.ts --target=darwin-x64",
        "vendor:rg:linux": "tsx scripts/vendor-rg.ts --target=linux-x64",
        "build:app": "vite build",
        "build": "pnpm run generated:check && pnpm run build:app",
        "build:win": "pnpm run vendor:node:win && pnpm run vendor:rg:win && pnpm run build && electron-builder --win -c electron-builder.json5",
        "build:mac": "pnpm run vendor:node:mac && pnpm run vendor:rg:mac && pnpm run build && electron-builder --mac --arm64 --x64 -c electron-builder.json5",
        "build:mac:arm64": "pnpm run vendor:node:mac:arm64 && pnpm run vendor:rg:mac:arm64 && pnpm run build && electron-builder --mac --arm64 -c electron-builder.json5",
        "build:mac:x64": "pnpm run vendor:node:mac:x64 && pnpm run vendor:rg:mac:x64 && pnpm run build && electron-builder --mac --x64 -c electron-builder.json5",
        "build:linux": "pnpm run vendor:node:linux && pnpm run vendor:rg:linux && pnpm run build && electron-builder --linux -c electron-builder.json5",
        "publish:generic": "tsx scripts/publish.ts",
        "migrate:runtime": "tsx scripts/migrate-runtime.ts",
        "persistence:released-fixtures:check": "tsx scripts/released-db-upgrade-fixtures.ts",
        "provider:catalog:drift": "tsx scripts/provider-catalog-drift-report.ts",
        "typecheck": "tsc --noEmit -p tsconfig.renderer.json && tsc --noEmit -p tsconfig.node.json",
        "lint": "tsx scripts/code-quality.ts lint",
        "lint:fix": "pnpm run lint -- --fix",
        "format": "tsx scripts/code-quality.ts format",
        "format:check": "tsx scripts/code-quality.ts format:check",
        "test": "vitest run --fileParallelism=false",
        "test:watch": "vitest"
    },
    "dependencies": {
        "@modelcontextprotocol/sdk": "^1.29.0",
        "@pierre/diffs": "1.1.22",
        "@pierre/trees": "1.0.0-beta.3",
        "@radix-ui/react-slot": "^1.2.4",
        "@tanstack/ai": "^0.16.0",
        "@tanstack/react-form": "^1.32.0",
        "@tanstack/react-query": "^5.100.10",
        "@tanstack/react-router": "^1.169.2",
        "@tanstack/react-virtual": "^3.13.24",
        "@trpc/client": "^11.17.0",
        "@trpc/react-query": "^11.17.0",
        "@trpc/server": "^11.17.0",
        "arktype": "^2.2.0",
        "class-variance-authority": "^0.7.1",
        "clsx": "^2.1.1",
        "electron-store": "^11.0.2",
        "electron-trpc-experimental": "1.0.0-alpha.1",
        "evlog": "^2.17.0",
        "kysely": "^0.29.0",
        "lucide-react": "^1.14.0",
        "neverthrow": "^8.2.0",
        "pdfjs-dist": "^5.7.284",
        "react": "^19.2.6",
        "react-dom": "^19.2.6",
        "react-markdown": "^10.1.0",
        "remark-gfm": "^4.0.1",
        "remark-parse": "^11.0.0",
        "remark-stringify": "^11.0.0",
        "semver": "^7.8.0",
        "shiki": "^4.0.2",
        "strip-markdown": "^6.0.0",
        "tailwind-merge": "^3.6.0",
        "tiktoken": "^1.0.22",
        "unified": "^11.0.5",
        "ws": "^8.20.1",
        "zustand": "^5.0.13"
    },
    "devDependencies": {
        "@bufferings/eslint-plugin-neverthrow": "0.3.0",
        "@eslint/compat": "^2.1.0",
        "@eslint/js": "^9.39.4",
        "@rolldown/plugin-babel": "^0.2.3",
        "@tailwindcss/forms": "^0.5.11",
        "@tailwindcss/vite": "^4.3.0",
        "@tanstack/devtools-vite": "^0.7.0",
        "@tanstack/eslint-plugin-query": "^5.100.10",
        "@tanstack/react-devtools": "^0.10.5",
        "@tanstack/react-form-devtools": "^0.2.27",
        "@tanstack/react-query-devtools": "^5.100.10",
        "@tanstack/react-router-devtools": "^1.166.13",
        "@tanstack/router-cli": "^1.166.43",
        "@tanstack/router-plugin": "^1.167.35",
        "@types/node": "^25.7.0",
        "@types/react": "^19.2.14",
        "@types/react-dom": "^19.2.3",
        "@types/semver": "^7.7.1",
        "@types/ws": "^8.18.1",
        "@vitejs/plugin-react": "^6.0.1",
        "@vitest/eslint-plugin": "^1.6.17",
        "babel-plugin-react-compiler": "^1.0.0",
        "electron": "^42.0.1",
        "electron-builder": "^26.8.1",
        "electron-updater": "^6.8.3",
        "eslint": "^9.39.4",
        "eslint-config-prettier": "^10.1.8",
        "eslint-import-resolver-typescript": "^4.4.4",
        "eslint-plugin-import": "^2.32.0",
        "eslint-plugin-jsx-a11y": "^6.10.2",
        "eslint-plugin-n": "^18.0.1",
        "eslint-plugin-no-secrets": "^2.3.3",
        "eslint-plugin-react": "^7.37.5",
        "eslint-plugin-react-hooks": "^7.1.1",
        "eslint-plugin-react-refresh": "^0.5.2",
        "eslint-plugin-security": "^4.0.0",
        "globals": "^17.6.0",
        "prettier": "^3.8.3",
        "prettier-plugin-tailwindcss": "^0.8.0",
        "tailwind-clamp": "^4.5.1",
        "tailwindcss": "^4.3.0",
        "tsx": "^4.21.0",
        "typescript": "~5.9.3",
        "typescript-eslint": "^8.59.3",
        "vite": "^8.0.12",
        "vite-plugin-electron": "^0.29.1",
        "vitest": "^4.1.6",
        "yaml": "^2.9.0"
    }
}
